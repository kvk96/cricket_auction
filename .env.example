# Backend Configuration
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Database
DATABASE_URL=postgresql://cricket_user:cricket_pass@localhost:5432/cricket_auction_db

# JWT
SECRET_KEY=your-secret-key-change-in-production-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend
FRONTEND_HOST=localhost
FRONTEND_PORT=4200
FRONTEND_BUILD_PATH=./dist/cricket-auction

# CORS
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# File Upload
UPLOAD_DIRECTORY=./uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp
ALLOWED_VIDEO_TYPES=mp4,avi,mov,mkv

# Email (for verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@cricketauction.local

# AWS/Storage (if needed for backups)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# Environment
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
